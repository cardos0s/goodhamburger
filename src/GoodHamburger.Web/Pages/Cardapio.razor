@page "/cardapio"
@inject GoodHamburger.Web.Services.GoodHamburgerApi Api
@inject NavigationManager Nav
@using GoodHamburger.Web.Models

<PageTitle>Cardápio — Good Hamburger</PageTitle>

<div class="page-header">
    <h1>Cardápio</h1>
    <input type="text" class="search-input" placeholder="🔍  Buscar produtos..."
           @bind="filtroNome" @bind:event="oninput" />
</div>

<div class="filter-chips">
    <button class="chip @(filtroCategoria is null ? "active" : "")"
            @onclick="() => filtroCategoria = null">
        Todos
    </button>
    <button class="chip @(filtroCategoria == CategoriaProduto.Sanduiche ? "active" : "")"
            @onclick="() => filtroCategoria = CategoriaProduto.Sanduiche">
        Hambúrgueres
    </button>
    <button class="chip @(filtroCategoria == CategoriaProduto.Batata ? "active" : "")"
            @onclick="() => filtroCategoria = CategoriaProduto.Batata">
        Acompanhamentos
    </button>
    <button class="chip @(filtroCategoria == CategoriaProduto.Refrigerante ? "active" : "")"
            @onclick="() => filtroCategoria = CategoriaProduto.Refrigerante">
        Bebidas
    </button>
</div>

@if (produtos is null)
{
    <p class="loading">Carregando cardápio...</p>
}
else if (!ProdutosFiltrados.Any())
{
    <p class="empty-state">Nenhum produto encontrado.</p>
}
else
{
    <div class="produtos-grid">
        @foreach (var produto in ProdutosFiltrados)
        {
            var produtoLocal = produto;
            <div class="produto-card">
                <div class="produto-imagem" style="background-image: url('@produto.ImagemUrl')"></div>
                <div class="produto-info">
                    <h3>@produto.Nome</h3>
                    <p class="produto-desc">@DescricaoDoProduto(produto)</p>
                    <div class="produto-footer">
                        <span class="produto-preco">R$ @produto.Preco.ToString("F2")</span>
                        <button class="btn-add" @onclick="() => AdicionarAoPedido(produtoLocal)">+</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private IReadOnlyList<ProdutoDto>? produtos;
    private CategoriaProduto? filtroCategoria;
    private string filtroNome = string.Empty;

    private IEnumerable<ProdutoDto> ProdutosFiltrados =>
        (produtos ?? Array.Empty<ProdutoDto>())
            .Where(p => filtroCategoria is null || p.Categoria == filtroCategoria)
            .Where(p => string.IsNullOrWhiteSpace(filtroNome) ||
                        p.Nome.Contains(filtroNome, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        produtos = await Api.ObterCardapioAsync();
    }

    private void AdicionarAoPedido(ProdutoDto produto)
    {
        Nav.NavigateTo($"/pedidos?produto={produto.Id}");
    }

    private static string DescricaoDoProduto(ProdutoDto p) => p.Id switch
    {
        1 => "Pão brioche, 180g de angus, queijo cheddar e molho especial.",
        2 => "Pão brioche, 180g de angus, ovo, queijo cheddar e bacon.",
        3 => "Pão brioche, 180g de angus, bacon crocante e molho barbecue.",
        4 => "Batata frita crocante e sequinha.",
        5 => "Refrigerante gelado 350ml.",
        _ => "Delicioso item do nosso cardápio."
    };
}